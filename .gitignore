# Dependencies
node_modules/

# Build output
dist/

# Database files
*.db
*.db-shm
*.db-wal

# Config with auth tokens — never commit credentials
.codegraph/config.json
**/.codegraph/config.json

# Runtime state — machine-specific paths, generated by claude-lore init/worker
.codegraph/exports.manifest
.codegraph/coverage-report.md
.codegraph/*.db
**/.codegraph/exports.manifest
**/.codegraph/coverage-report.md
**/.codegraph/*.db

# Hook configs — generated by claude-lore init, contain absolute machine paths
# Use templates/claude-settings.json and templates/cursor-*.json as reference instead
.claude/settings.json
.cursor/hooks.json
.cursor/mcp.json

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
